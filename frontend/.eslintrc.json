{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "extends": [
        "eslint:recommended"
    ],
    "plugins": [
        "import"
    ],
    "rules": {
        "import/no-unused-modules": [
            "warn",
            {
                "unusedExports": true,
                "missingExports": false
            }
        ]
    }
}
